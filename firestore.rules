rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Allow authenticated users to read and write to all collections
    // This is to ensure buttons are not blocked during development/prototype phase
    // Allow public read access to non-sensitive collections
    // Write access still requires authentication
    
    match /notices/{noticeId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /posts/{postId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /gallery/{imageId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /homework/{homeworkId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /attendance/{classId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /suggestions/{suggestionId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /routines/{classId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /results/{resultId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /exam_charges/{chargeId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /class_notices/{noticeId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /pdfs/{pdfId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /users/{userId} {
      // Allow reading user profiles (needed for gallery/posts)
      // But restrict writing to the user themselves or an admin
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    // Default deny for anything else
    match /{document=**} {
      allow read, write: if isAuthenticated();
    }
  }
}
